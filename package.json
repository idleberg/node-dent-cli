{
	"name": "@nsis/dent-cli",
	"version": "0.2.0",
	"description": "An opinionated code formatter for NSIS scripts",
	"license": "MIT",
	"scripts": {
		"build": "tsup",
		"dev": "npm run start",
		"fix": "eslint --fix ./src",
		"lint:json": "eslint ./*.json --ignore-path .gitignore",
		"lint:ts": "eslint ./src --ignore-path .gitignore",
		"lint": "npm-run-all --parallel lint:*",
		"prepack": "npm run build",
		"start": "npm run build -- --watch",
		"test": "echo \"Tests pending\" && exit 0",
		"prepare": "husky install"
	},
	"files": [
		"bin/",
		"LICENSE",
		"README.md"
	],
	"type": "module",
	"typings": "bin/cli.d.ts",
	"bin": {
		"dent": "bin/cli.mjs"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/idleberg/node-dent-cli.git"
	},
	"keywords": [
		"nsis",
		"formatter"
	],
	"dependencies": {
		"@nsis/dent": "^0.4.1",
		"commander": "^11.1.0",
		"glob": "^10.3.10",
		"log-symbols": "^6.0.0",
		"picocolors": "^1.0.0"
	},
	"devDependencies": {
		"@idleberg/configs": "^0.4.2",
		"@types/node": "^18.19.3",
		"concurrently": "^9.2.1",
		"tsdown": "^0.20.3",
		"typescript": "^5.3.3"
	},
	"packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
